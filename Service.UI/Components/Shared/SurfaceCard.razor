@namespace Service.UI.Components.Shared
@using Microsoft.AspNetCore.Components

<div class="surface-card @Class">
    @if (HeaderContent is not null || HeaderActions is not null)
    {
        <div class="surface-card-header">
            <div class="surface-card-header-main">
                @HeaderContent
            </div>
            @if (HeaderActions is not null)
            {
                <div class="surface-card-header-actions">
                    @HeaderActions
                </div>
            }
        </div>
    }

    <div class="surface-card-body">
        @ChildContent
    </div>
</div>

@code {
    [Parameter]
    public string Class { get; set; } = string.Empty;

    [Parameter]
    public RenderFragment? HeaderContent { get; set; }

    [Parameter]
    public RenderFragment? HeaderActions { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}
